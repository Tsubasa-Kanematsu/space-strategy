# ============================================================
# space-strategy — 環境変数テンプレート
# このファイルをコピーして .env を作成してください。
# ============================================================

# フロントエンドが叩く API のベース URL。
# 同一オリジン (Express が SPA も配信) なら空のままでよい。
VITE_API_URL=

# ── サーバー (server/index.js) 用 ─────────────────────────────
# 共有ログインパスワード (本番は必ず変更)
APP_PASSWORD=spacestrategy
# JWT 署名鍵 (本番は十分に長いランダム文字列)
JWT_SECRET=dev-insecure-secret-change-me
# データ保存先 (Render では永続ディスクのマウント先)
DATA_DIR=./data
# 待受ポート (Render が PORT を注入する)
PORT=3000
